@startuml
title Add Calendar Appointment - Core Algorithm

actor User
boundary "CalendarMainFrame" as CalendarMainFrame
boundary "AddAppointmentDialog" as AddAppointmentDialog
control "AppointmentController" as AppointmentController
control "AppointmentValidator" as AppointmentValidator
control "CalendarService" as CalendarService
entity "Calendar" as Calendar
entity "Appointment" as Appointment
entity "Reminder" as Reminder
entity "GroupMeeting" as GroupMeeting

User -> CalendarMainFrame : clicks Add Appointment
CalendarMainFrame -> AddAppointmentDialog : open dialog
User -> AddAppointmentDialog : enters appointment details
AddAppointmentDialog -> Appointment : create appointment
opt reminder selected
    AddAppointmentDialog -> Reminder : create reminder
end

AddAppointmentDialog -> AppointmentController : addAppointment(user, appointment, reminder, decisions)
AppointmentController -> AppointmentValidator : validate(appointment)
AppointmentValidator --> AppointmentController : ValidationResult

alt invalid input
    AppointmentController --> AddAppointmentDialog : failure(validation message)
    AddAppointmentDialog --> User : show validation error
else valid input
    AppointmentController -> CalendarService : findConflict(appointment)
    CalendarService -> Calendar : findConflict(appointment)
    Calendar --> CalendarService : Optional<Appointment>
    CalendarService --> AppointmentController : Optional<Appointment>

    alt conflict appointment exists
        AppointmentController --> AddAppointmentDialog : ask choose another time or replace

        alt choose another time
            AddAppointmentDialog --> User : ask for another available time
        else replace existing
            AppointmentController -> CalendarService : replaceAppointment(user, oldAppointment, appointment)
            CalendarService -> Calendar : removeAppointment(oldAppointment)
            CalendarService -> Calendar : addAppointment(appointment)
            CalendarService -> User : removeAppointment(oldAppointment)
            CalendarService -> User : addAppointment(appointment)
            opt reminder selected
                AppointmentController -> CalendarService : addReminder(user, reminder)
                CalendarService -> Calendar : addReminder(reminder)
                CalendarService -> User : addReminder(reminder)
            end
            AppointmentController --> AddAppointmentDialog : success(replaced)
        end
    else no conflict
        AppointmentController -> CalendarService : findMatchingGroupMeeting(appointment)
        CalendarService -> Calendar : findMatchingGroupMeeting(appointment)
        Calendar --> CalendarService : Optional<GroupMeeting>
        CalendarService --> AppointmentController : Optional<GroupMeeting>

        alt matching group meeting exists
            AppointmentController --> AddAppointmentDialog : ask join or create separate

            alt join group meeting
                AppointmentController -> CalendarService : joinGroupMeeting(user, groupMeeting)
                CalendarService -> User : joinGroupMeeting(groupMeeting)
                User -> GroupMeeting : addParticipant(user)
                AppointmentController --> AddAppointmentDialog : success(joined group meeting)
            else create separate appointment
                AppointmentController -> CalendarService : addAppointment(user, appointment)
                CalendarService -> Calendar : addAppointment(appointment)
                CalendarService -> User : addAppointment(appointment)
                opt reminder selected
                    AppointmentController -> CalendarService : addReminder(user, reminder)
                    CalendarService -> Calendar : addReminder(reminder)
                    CalendarService -> User : addReminder(reminder)
                end
                AppointmentController --> AddAppointmentDialog : success(added appointment)
            end
        else no matching group meeting
            AppointmentController -> CalendarService : addAppointment(user, appointment)
            CalendarService -> Calendar : addAppointment(appointment)
            CalendarService -> User : addAppointment(appointment)
            opt reminder selected
                AppointmentController -> CalendarService : addReminder(user, reminder)
                CalendarService -> Calendar : addReminder(reminder)
                CalendarService -> User : addReminder(reminder)
            end
            AppointmentController --> AddAppointmentDialog : success(added appointment)
        end
    end

    AddAppointmentDialog --> User : show result message
end

@enduml
